<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{{ template "title" . }}</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-0evHe/X+R7YkIZDRvuzKMRqM+OrBnVFBL6DOitfPri4tjfHxaWutUpFmBp4vmVor" crossorigin="anonymous">
		<link rel="shortcut icon" href="/static/favicon.png" type="image/png">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.3/font/bootstrap-icons.css">
		<style>
		h1 { padding-top: 1.2rem !important; padding-bottom: 0 !important; font-size: 1.5rem; }
		.bi { font-size: 1.5em; }
		td { vertical-align: middle; }
		.history-row td { padding-top: .45rem; padding-bottom: 1rem; border-top: 0; }
		.history-bar { display: grid; gap: 2px; width: 100%; min-height: 2rem; }
		.history-day-wrap { position: relative; display: block; min-width: 2px; outline: none; }
		.history-day { display: block; min-width: 2px; height: 2rem; border-radius: 2px; }
		.history-day-split { display: flex; flex-direction: column; gap: 0; overflow: hidden; }
		.history-lane { display: block; flex: 1 1 0; min-height: 0; }
		.history-day-ok { background: #198754; }
		.history-day-maintenance { background: #ffc107; }
		.history-day-outage { background: #dc3545; }
		.history-popover { display: none; position: absolute; left: 50%; bottom: 100%; z-index: 1080; width: max-content; min-width: 14rem; max-width: 22rem; padding: .65rem .75rem; color: #212529; background: #fff; border: 1px solid rgba(0,0,0,.2); border-radius: .3rem; box-shadow: 0 .5rem 1rem rgba(0,0,0,.15); transform: translateX(-50%); font-size: .875rem; line-height: 1.25; white-space: normal; }
		.history-day-wrap:hover .history-popover, .history-day-wrap:focus-within .history-popover { display: block; }
		.history-day-wrap:focus-visible .history-day { box-shadow: 0 0 0 .2rem rgba(13,110,253,.25); }
		.history-popover-date { display: block; margin-bottom: .35rem; font-weight: 600; }
		.history-popover-list { margin: 0; padding-left: 1rem; }
		.history-popover-list li + li { margin-top: .25rem; }
		.history-popover-empty { color: #6c757d; }
		</style>
	</head>
	<body>
		<div class="container">
			{{ template "content" . }}

			<footer class="row py-3 my-4">
				<div class="col">
					<p class="text-start">
						<a href="/json" class="link-secondary">JSON</a>
						| <a href="/metrics" class="link-secondary">Prometheus metrics</a>
						| <a href="/about" class="link-secondary">About</a>
					</p>
				</div>
				<div class="col">
					<p class="text-end text-muted">vpsFree.cz</p>
				</div>
			</footer>
		</div>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/js/bootstrap.bundle.min.js" integrity="sha384-pprn3073KE6tl6bjs2QrFaJGz5/SUsLqktiwsUTF55Jfv3qYSDhgCecCxMW52nD2" crossorigin="anonymous"></script>
	</body>
</html>
