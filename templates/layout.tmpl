<!doctype html>
<html lang="{{ .Locale.HTML }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{{ template "title" . }}</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-0evHe/X+R7YkIZDRvuzKMRqM+OrBnVFBL6DOitfPri4tjfHxaWutUpFmBp4vmVor" crossorigin="anonymous">
		<link rel="shortcut icon" href="/static/favicon.png" type="image/png">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.3/font/bootstrap-icons.css">
		<style>
		h1 { padding-top: 1.2rem !important; padding-bottom: 0 !important; font-size: 1.5rem; }
		.bi { font-size: 1.5em; }
		td { vertical-align: middle; }
		.group-detail-link:hover, .group-detail-link:focus-visible { text-decoration: underline !important; }
		.history-row td { padding-top: .45rem; padding-bottom: 1rem; border-top: 0; }
		.history-bar { display: grid; gap: 2px; width: 100%; min-height: 2rem; }
		.history-day-wrap { position: relative; display: block; min-width: 2px; outline: none; }
		.history-day { display: block; min-width: 2px; height: 2rem; border-radius: 2px; }
		.history-day-split { display: flex; flex-direction: column; gap: 0; overflow: hidden; }
		.history-lane { display: block; flex: 1 1 0; min-height: 0; }
		.history-day-ok { background: #198754; }
		.history-day-maintenance { background: #ffc107; }
		.history-day-outage { background: #dc3545; }
		.history-popover { display: none; position: fixed; left: 0; top: 0; z-index: 1080; width: max-content; min-width: min(14rem, calc(100vw - 1rem)); max-width: min(22rem, calc(100vw - 1rem)); max-height: calc(100vh - 1rem); overflow-y: auto; padding: .65rem .75rem; color: #212529; background: #fff; border: 1px solid rgba(0,0,0,.2); border-radius: .3rem; box-shadow: 0 .5rem 1rem rgba(0,0,0,.15); transform: none; font-size: .875rem; line-height: 1.25; white-space: normal; }
		.history-day-wrap:hover .history-popover, .history-day-wrap:focus-within .history-popover { display: block; }
		.history-day-wrap:focus-visible .history-day { box-shadow: 0 0 0 .2rem rgba(13,110,253,.25); }
		.history-popover-date { display: block; margin-bottom: .35rem; font-weight: 600; }
		.history-popover-list { margin: 0; padding-left: 1rem; }
		.history-popover-list li + li { margin-top: .25rem; }
		.history-popover-incident-title { display: block; }
		.history-popover-meta { display: block; margin-top: .15rem; color: #6c757d; font-size: .8125rem; }
		.history-popover-meta span { display: block; }
		.history-popover-empty { color: #6c757d; }
		.probe-covered-danger { --probe-covered-color: #dc3545; }
		.probe-covered-warning { --probe-covered-color: #ffc107; }
		.probe-covered td:first-child { box-shadow: inset .25rem 0 0 var(--probe-covered-color); }
		.probe-covered:not(.probe-covered-start) td { border-top-color: transparent; }
		.probe-covered-start td { border-top-width: 2px; }
		.probe-covered-end td { border-bottom-width: 2px; }
		</style>
	</head>
	<body>
		<div class="container">
			{{ template "content" . }}

			<footer class="row py-3 my-4">
				<div class="col">
					<p class="text-start">
						<a href="/json" class="link-secondary">JSON</a>
						| <a href="/metrics" class="link-secondary">{{ .Locale.T "footer.prometheus_metrics" }}</a>
						| <a href="{{ .Locale.URL "/about" }}" class="link-secondary">{{ .Locale.T "footer.about" }}</a>
					</p>
				</div>
				<div class="col">
					<p class="text-end text-muted">vpsFree.cz</p>
				</div>
			</footer>
		</div>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/js/bootstrap.bundle.min.js" integrity="sha384-pprn3073KE6tl6bjs2QrFaJGz5/SUsLqktiwsUTF55Jfv3qYSDhgCecCxMW52nD2" crossorigin="anonymous"></script>
		<script>
		(() => {
			const margin = 8;
			const gap = 8;
			let activeWrap = null;
			let frame = 0;

			function popoverFor(wrap) {
				return wrap ? wrap.querySelector(".history-popover") : null;
			}

			function isActive(wrap) {
				return wrap && (wrap.matches(":hover") || wrap.matches(":focus-within"));
			}

			function clamp(value, size, viewportSize) {
				const max = Math.max(margin, viewportSize - size - margin);
				return Math.min(Math.max(value, margin), max);
			}

			function positionPopover(wrap) {
				const popover = popoverFor(wrap);
				if (!popover || !isActive(wrap)) {
					return;
				}

				popover.style.visibility = "hidden";
				popover.style.left = "0px";
				popover.style.top = "0px";

				const triggerRect = wrap.getBoundingClientRect();
				const popoverRect = popover.getBoundingClientRect();
				const width = popoverRect.width;
				const height = popoverRect.height;

				const centeredLeft = triggerRect.left + triggerRect.width / 2 - width / 2;
				const left = clamp(centeredLeft, width, window.innerWidth);
				const aboveTop = triggerRect.top - height - gap;
				const belowTop = triggerRect.bottom + gap;
				let top = aboveTop;
				if (aboveTop < margin && belowTop + height <= window.innerHeight - margin) {
					top = belowTop;
				}

				popover.style.left = `${left}px`;
				popover.style.top = `${clamp(top, height, window.innerHeight)}px`;
				popover.style.visibility = "visible";
			}

			function schedulePosition(wrap) {
				activeWrap = wrap;
				if (frame) {
					cancelAnimationFrame(frame);
				}
				frame = requestAnimationFrame(() => {
					frame = 0;
					positionPopover(wrap);
				});
			}

			function repositionActive() {
				if (isActive(activeWrap)) {
					schedulePosition(activeWrap);
				}
			}

			document.addEventListener("pointerenter", (event) => {
				const wrap = event.target.closest(".history-day-wrap");
				if (wrap) {
					schedulePosition(wrap);
				}
			}, true);

			document.addEventListener("focusin", (event) => {
				const wrap = event.target.closest(".history-day-wrap");
				if (wrap) {
					schedulePosition(wrap);
				}
			});

			document.addEventListener("focusout", () => {
				requestAnimationFrame(() => {
					if (!isActive(activeWrap)) {
						activeWrap = null;
					}
				});
			});

			window.addEventListener("resize", repositionActive);
			window.addEventListener("scroll", repositionActive, true);
		})();
		</script>
	</body>
</html>
