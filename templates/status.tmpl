										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
								</tr>
								<tr class="history-row">
									<td colspan="3">{{ template "history_bar" ($.Status.HistoryFor "web_service" $ws.Label) }}</td>
								</tr>
								{{ end }}
							</tbody>
						</table>
					</div>
				</div>
			</div> <!-- accordion item -->

			<div class="accordion-item">
				<h3 class="accordion-header" id="heading-nameservers">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-nameservers" aria-expanded="true" aria-controls="collapse-nameservers">
						{{ .Locale.T "section.name_servers" }} {{ template "status_counts" (dict "Counts" .Status.Services.NameServerCounts "Locale" .Locale) }}
					</button>
				</h3>
				<div id="collapse-nameservers" class="accordion-collapse collapse" aria-labelledby="heading-nameservers">
					<div class="accordion-body">
						<table class="table table-sm">
							<thead>
								<tr>
									<th>{{ $.Locale.T "table.service" }}</th>
									<th>{{ $.Locale.T "table.ping" }}</th>
									<th>{{ $.Locale.T "table.lookup" }}</th>
								</tr>
							</thead>
							<tbody>
								{{ range $ns := .Status.Services.NameServer }}
								<tr class="table-{{ if $ns.IsOperational }}success{{ else if $ns.IsDegraded }}warning{{ else }}danger{{ end }}">
									<td><a href="{{ $.Status.DetailURL "nameserver" $ns.Name }}">{{ $ns.Name }}</a></td>
									<td>
										{{ if $ns.Ping.IsUp }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.responding" }}" title="{{ $.Locale.T "status.responding" }}"></i>
										{{ else if $ns.Ping.IsWarning }}
										<i class="bi bi-question-circle text-warning" aria-label="{{ $.Locale.T "status.degraded" }}" title="{{ $.Locale.T "status.degraded" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
									<td>
										{{ if $ns.ResolveStatus }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.operational" }}" title="{{ $.Locale.T "status.operational" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.error" }}" title="{{ $.Locale.T "status.error" }}"></i>
										{{ end }}
									</td>
								</tr>
								<tr class="history-row">
									<td colspan="3">{{ template "history_bar" ($.Status.HistoryFor "nameserver" $ns.Name) }}</td>
								</tr>
								{{ end }}
							</tbody>
						</table>
					</div>
				</div>
			</div> <!-- accordion item -->
		</div>
	</div>
</div>
{{ end }}
