{{ define "title" }}{{ .Locale.T "app.title" }}{{ end }}

{{ define "status_counts" }}<span class="status-counts ms-1" aria-label="{{ .Locale.TD "status_counts.aria" (dict "Operational" .Counts.Operational "Degraded" .Counts.Degraded "Down" .Counts.Down "Total" .Counts.Total) }}"><span class="text-success" title="{{ .Locale.T "status.operational" }}">{{ .Counts.Operational }}</span>{{ if gt .Counts.Degraded 0 }}/<span class="text-warning" title="{{ .Locale.T "status.degraded_or_maintenance" }}">{{ .Counts.Degraded }}</span>{{ end }}{{ if gt .Counts.Down 0 }}/<span class="text-danger" title="{{ .Locale.T "status.down" }}">{{ .Counts.Down }}</span>{{ end }}/<span class="text-body" title="{{ .Locale.T "status.total" }}">{{ .Counts.Total }}</span></span>{{ end }}

{{ define "content" }}
{{ template "index_header" . }}
{{ template "index_body" . }}
{{ end }}

{{ define "index_body" }}
{{ if .Notice.Any }}
<div class="row">
	<div class="col">
		<div class="alert alert-primary" role="alert">
			{{ .Notice.Html }}
			<hr>
			<p>{{ .Locale.TD "notice.updated_at" (dict "UpdatedAt" .NoticeUpdatedAt) }}</p>
		</div>
	</div>
</div>
{{ end }}

{{ $webuiUrl := .Status.VpsAdmin.Webui.Url }}
<div class="row">
	<div class="col">
		{{ if .Status.OutageReports.AnyActive }}
		<h2>{{ .Status.OutageReports.ActiveTitleForLocale .Locale }}</h2>
		<table class="table table-sm">
			<thead>
				<tr>
					<th>{{ .Locale.T "table.date" }}</th>
					<th>{{ .Locale.T "table.duration" }}</th>
					<th>{{ .Locale.T "table.type" }}</th>
					<th>{{ .Locale.T "table.systems" }}</th>
					<th>{{ .Locale.T "table.impact" }}</th>
					<th>{{ .Locale.T "table.reason" }}</th>
					<th>{{ .Locale.T "table.link" }}</th>
				</tr>
			</thead>
			<tbody>
				{{ $status := .Status }}
				{{ range $outage := .Status.OutageReports.ActiveList }}
				<tr class="table-{{ if $outage.IsPlannedOutage }}warning{{ else }}danger{{ end }}">
					<td>{{ $outage.BeginsAt.Local.Format "2006-01-02 15:04 MST" }}</td>
					<td>{{ $outage.Duration }}</td>
					<td>
						{{ if $outage.IsPlannedOutage }}
						<i class="bi bi-clipboard2-check text-success" aria-label="{{ $outage.TypeLabelForLocale $.Locale }}" title="{{ $outage.TypeLabelForLocale $.Locale }}"></i>
						{{ else }}
						<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $outage.TypeLabelForLocale $.Locale }}" title="{{ $outage.TypeLabelForLocale $.Locale }}"></i>
						{{ end }}
					</td>
					<td>
						{{ range $i, $entity := $outage.AffectedEntities }}{{ if $i }}, {{ end }}{{ $entity.DisplayLabel }}{{ end }}
					</td>
					<td>{{ $outage.ImpactLabelForLocale $.Locale }}</td>
					<td>{{ $outage.SummaryForLocale $.Locale }}</td>
					<td>
						<a href="{{ $webuiUrl }}/?page=outage&action=show&id={{ $outage.Id }}" target="_blank">{{ $.Locale.T "outage.more_information" }}</a>
					</td>
				</tr>
				{{ end }}
			</tbody>
		</table>
		{{ end }}
		{{ if .Status.OutageReports.AnyRecent }}
		<h2>{{ .Status.OutageReports.RecentTitleForLocale .Locale }}</h2>
		<table class="table table-sm">
			<thead>
				<tr>
					<th>{{ .Locale.T "table.date" }}</th>
					<th>{{ .Locale.T "table.duration" }}</th>
					<th>{{ .Locale.T "table.type" }}</th>
					<th>{{ .Locale.T "table.systems" }}</th>
					<th>{{ .Locale.T "table.impact" }}</th>
					<th>{{ .Locale.T "table.reason" }}</th>
					<th>{{ .Locale.T "table.link" }}</th>
				</tr>
			</thead>
			<tbody>
				{{ $status := .Status }}
				{{ range $outage := .Status.OutageReports.RecentList }}
				<tr class="table-{{ if $outage.IsPlannedOutage }}warning{{ else }}danger{{ end }}">
					<td>{{ $outage.BeginsAt.Local.Format "2006-01-02 15:04 MST" }}</td>
					<td>{{ $outage.Duration }}</td>
					<td>
						{{ if $outage.IsPlannedOutage }}
						<i class="bi bi-clipboard2-check text-success" aria-label="{{ $outage.TypeLabelForLocale $.Locale }}" title="{{ $outage.TypeLabelForLocale $.Locale }}"></i>
						{{ else }}
						<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $outage.TypeLabelForLocale $.Locale }}" title="{{ $outage.TypeLabelForLocale $.Locale }}"></i>
						{{ end }}
					</td>
					<td>
						{{ range $i, $entity := $outage.AffectedEntities }}{{ if $i }}, {{ end }}{{ $entity.DisplayLabel }}{{ end }}
					</td>
					<td>{{ $outage.ImpactLabelForLocale $.Locale }}</td>
					<td>{{ $outage.SummaryForLocale $.Locale }}</td>
					<td>
						<a href="{{ $webuiUrl }}/?page=outage&action=show&id={{ $outage.Id }}" target="_blank">{{ $.Locale.T "outage.more_information" }}</a>
					</td>
				</tr>
				{{ end }}
			</tbody>
		</table>
		{{ end }}
		{{ if and (.Status.OutageReports.Status) (not .Status.OutageReports.AnyActive) (not .Status.OutageReports.AnyRecent) }}
			{{ if not .Notice.Any }}
			<div class="alert alert-success">
				{{ .Locale.T "outages.no_issues" }} <a href="{{ $webuiUrl }}/?page=outage&action=list" target="_blank">{{ .Locale.T "outages.history" }}</a>.
			</div>
			{{ end }}
		{{ end }}
		{{ if not .Status.OutageReports.Status }}
		<div class="alert alert-danger" role="alert">
			{{ .Locale.T "outages.unable_fetch" }}
		</div>
		{{ end }}
		{{ if .Status.SecurityAdvisories.AnyRecent }}
		<h2>{{ .Locale.T "security.recent" }}</h2>
		<table class="table table-sm">
			<thead>
				<tr>
					<th>{{ .Locale.T "table.published" }}</th>
					<th>{{ .Locale.T "table.cve" }}</th>
					<th>{{ .Locale.T "table.summary" }}</th>
					<th>{{ .Locale.T "table.link" }}</th>
				</tr>
			</thead>
			<tbody>
				{{ range $advisory := .Status.SecurityAdvisories.RecentList }}
				<tr class="table-info">
					<td>{{ $advisory.PublishedAt.Local.Format "2006-01-02 15:04 MST" }}</td>
					<td>{{ $advisory.CveLabel }}</td>
					<td>{{ $advisory.SummaryForLocale $.Locale }}</td>
					<td>
						<a href="{{ $webuiUrl }}/?page=security_advisory&action=show&id={{ $advisory.Id }}" target="_blank">{{ $.Locale.T "outage.more_information" }}</a>
					</td>
				</tr>
				{{ end }}
			</tbody>
		</table>
		{{ end }}
		{{ if not .Status.SecurityAdvisories.Status }}
		<div class="alert alert-danger" role="alert">
			{{ .Locale.T "security.unable_fetch" }}
		</div>
		{{ end }}
	</div>
</div>

<div class="row">
	<div class="col">
		<h2>
			<a class="text-body text-decoration-none group-detail-link" href="{{ .Status.GroupDetailURL "vpsadmin" "" }}">vpsAdmin {{ template "status_counts" (dict "Counts" .Status.VpsAdmin.Counts "Locale" .Locale) }}</a>
		</h2>
		<div class="mb-3">
			{{ template "history_bar" .Status.VpsAdmin.History }}
		</div>

		<div class="accordion" id="accordion-vpsadmin">
			<div class="accordion-item">
				<h3 class="accordion-header" id="heading-vpsadmin">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-vpsadmin" aria-expanded="true" aria-controls="collapse-vpsadmin">
						{{ .Locale.T "section.web_services" }} {{ template "status_counts" (dict "Counts" .Status.VpsAdmin.Counts "Locale" .Locale) }}
					</button>
				</h3>
				<div id="collapse-vpsadmin" class="accordion-collapse collapse" aria-labelledby="heading-vpsadmin">
					<div class="accordion-body">
						<table class="table table-sm">
							<thead>
								<tr>
									<th>{{ $.Locale.T "table.service" }}</th>
									<th>{{ $.Locale.T "table.description" }}</th>
									<th>{{ $.Locale.T "table.status" }}</th>
								</tr>
							</thead>
							<tbody>
								<tr class="table-{{ if .Status.VpsAdmin.Webui.Status }}success{{ else if .Status.VpsAdmin.Webui.Maintenance }}warning{{ else }}danger{{ end }}">
									<td><a href="{{ .Status.DetailURL "vpsadmin" "webui" }}">vpsadmin.vpsfree.cz</a></td>
									<td>{{ $.Locale.T "service.vpsadmin.webui.description" }}</td>
									<td>
										{{ if .Status.VpsAdmin.Webui.Maintenance }}
										<i class="bi bi-cone-striped text-muted" aria-label="{{ $.Locale.T "status.under_maintenance" }}" title="{{ $.Locale.T "status.under_maintenance" }}"></i>
										{{ else if .Status.VpsAdmin.Webui.Status }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.operational" }}" title="{{ $.Locale.T "status.operational" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
								</tr>
								<tr class="history-row">
									<td colspan="3">{{ template "history_bar" (.Status.HistoryFor "vpsadmin" "webui") }}</td>
								</tr>
								<tr class="table-{{ if .Status.VpsAdmin.Api.Status }}success{{ else if .Status.VpsAdmin.Api.Maintenance }}warning{{ else }}danger{{ end }}">
									<td><a href="{{ .Status.DetailURL "vpsadmin" "api" }}">api.vpsfree.cz</a></td>
									<td>{{ $.Locale.T "service.vpsadmin.api.description" }}</td>
									<td>
										{{ if .Status.VpsAdmin.Api.Maintenance }}
										<i class="bi bi-cone-striped text-muted" aria-label="{{ $.Locale.T "status.under_maintenance" }}" title="{{ $.Locale.T "status.under_maintenance" }}"></i>
										{{ else if .Status.VpsAdmin.Api.Status }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.operational" }}" title="{{ $.Locale.T "status.operational" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
								</tr>
								<tr class="history-row">
									<td colspan="3">{{ template "history_bar" (.Status.HistoryFor "vpsadmin" "api") }}</td>
								</tr>
								<tr class="table-{{ if .Status.VpsAdmin.Console.Status }}success{{ else if .Status.VpsAdmin.Console.Maintenance }}warning{{ else }}danger{{ end }}">
									<td><a href="{{ .Status.DetailURL "vpsadmin" "console" }}">{{ $.Locale.T "service.vpsadmin.console" }}</a></td>
									<td>{{ $.Locale.T "service.vpsadmin.console.description" }}</td>
									<td>
										{{ if .Status.VpsAdmin.Console.Maintenance }}
										<i class="bi bi-cone-striped text-muted" aria-label="{{ $.Locale.T "status.under_maintenance" }}" title="{{ $.Locale.T "status.under_maintenance" }}"></i>
										{{ else if .Status.VpsAdmin.Console.Status }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.operational" }}" title="{{ $.Locale.T "status.operational" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
								</tr>
								<tr class="history-row">
									<td colspan="3">{{ template "history_bar" (.Status.HistoryFor "vpsadmin" "console") }}</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

{{ range $loc := .Status.Locations }}
<div class="row mt-4 mb-4">
	<div class="column">
		<h2>
			<a class="text-body text-decoration-none group-detail-link" href="{{ $.Status.GroupDetailURL "location" $loc.Id }}">{{ $loc.Label }} {{ template "status_counts" (dict "Counts" $loc.Counts "Locale" $.Locale) }}</a>
		</h2>
		<div class="mb-3">
			{{ template "history_bar" $loc.History }}
		</div>

		<div class="accordion" id="accordion-location-{{ $loc.Id }}">
			<div class="accordion-item">
				<h3 class="accordion-header" id="heading-nodes-{{ $loc.Id }}">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-nodes-{{ $loc.Id }}" aria-expanded="true" aria-controls="collapse-nodes-{{ $loc.Id }}">
						{{ $.Locale.T "section.nodes" }} {{ template "status_counts" (dict "Counts" $loc.NodeCounts "Locale" $.Locale) }}
					</button>
				</h3>
				<div id="collapse-nodes-{{ $loc.Id }}" class="accordion-collapse collapse" aria-labelledby="heading-nodes-{{ $loc.Id }}">
					<div class="accordion-body">
						<table class="table table-sm">
							<thead>
								<tr>
									<th>{{ $.Locale.T "table.node" }}</th>
									<th>vpsAdmin</th>
									<th>{{ $.Locale.T "table.storage" }}</th>
									<th>{{ $.Locale.T "table.ping" }}</th>
								</tr>
							</thead>
							<tbody>
								{{ range $node := $loc.NodeList }}
								<tr class="table-{{ if $node.IsOperational }}success{{ else if $node.IsDegraded }}warning{{ else }}danger{{ end }}">
									<td><a href="{{ $.Status.DetailURL "node" $node.Name }}">{{ $node.Name }}</a></td>
									<td>
										{{ if $node.ApiStatus }}
											{{ if $node.ApiMaintenance }}
											<i class="bi bi-cone-striped text-muted" aria-label="{{ $.Locale.T "status.under_maintenance" }}" title="{{ $.Locale.T "status.under_maintenance" }}"></i>
											{{ else }}
											<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.operational" }}" title="{{ $.Locale.T "status.operational" }}"></i>
											{{ end }}
										{{ else }}
											<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
									<td>
										{{ if not $node.IsStorageSupported }}
										<i class="bi bi-dash-lg text-muted" aria-label="{{ $.Locale.T "status.not_supported" }}" title="{{ $.Locale.T "status.not_supported" }}"></i>
										{{ else if $node.ApiMaintenance }}
										<i class="bi bi-cone-striped text-muted" aria-label="{{ $.Locale.T "status.under_maintenance" }}" title="{{ $.Locale.T "status.under_maintenance" }}"></i>
										{{ else if $node.IsStorageOperational }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.online" }}" title="{{ $.Locale.T "status.online" }}"></i>
										{{ else if $node.IsStorageHardFailure }}
										<i class="bi bi-device-hdd-fill text-danger" aria-label="{{ $node.GetStorageStateMessageForLocale $.Locale }}" title="{{ $node.GetStorageStateMessageForLocale $.Locale }}"></i>
										{{ else if $node.IsStorageStateIssue }}
										<i class="bi bi-device-hdd-fill text-warning" aria-label="{{ $node.GetStorageStateMessageForLocale $.Locale }}" title="{{ $node.GetStorageStateMessageForLocale $.Locale }}"></i>
										{{ else if $node.IsStorageScanIssue }}
										<i class="bi bi-exclamation-circle text-warning" aria-label="{{ $node.GetStorageScanMessageForLocale $.Locale }}" title="{{ $node.GetStorageScanMessageForLocale $.Locale }}"></i>
										{{ else if $node.PoolStatus }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.online" }}" title="{{ $.Locale.T "status.online" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-warning" aria-label="{{ $node.GetStorageStateMessageForLocale $.Locale }}" title="{{ $node.GetStorageStateMessageForLocale $.Locale }}"></i>
										{{ end }}

										{{ if not $node.ApiMaintenance }}
											{{ if $node.IsStorageScrubIssue }}
											<i class="bi bi-search text-muted" aria-label="{{ $node.GetStorageScanMessageForLocale $.Locale }}" title="{{ $node.GetStorageScanMessageForLocale $.Locale }}"></i>
											{{ else if $node.IsStorageResilverIssue }}
											<i class="bi bi-search text-warning" aria-label="{{ $node.GetStorageScanMessageForLocale $.Locale }}" title="{{ $node.GetStorageScanMessageForLocale $.Locale }}"></i>
											{{ end }}
										{{ end }}
									</td>
									<td>
										{{ if $node.Ping.IsUp }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.responding" }}" title="{{ $.Locale.T "status.responding" }}"></i>
										{{ else if $node.Ping.IsWarning }}
										<i class="bi bi-question-circle text-warning" aria-label="{{ $.Locale.T "status.degraded" }}" title="{{ $.Locale.T "status.degraded" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
								</tr>
								<tr class="history-row">
									<td colspan="4">{{ template "history_bar" ($.Status.HistoryFor "node" $node.Name) }}</td>
								</tr>
								{{ end }}
							</tbody>
						</table>
					</div>
				</div>
			</div> <!-- accordion item -->

			{{ if $loc.HasDnsResolvers }}
			<div class="accordion-item">
				<h3 class="accordion-header" id="heading-dns-{{ $loc.Id }}">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-dns-{{ $loc.Id }}" aria-expanded="true" aria-controls="collapse-dns-{{ $loc.Id }}">
						{{ $.Locale.T "section.dns_resolvers" }} {{ template "status_counts" (dict "Counts" $loc.DnsResolverCounts "Locale" $.Locale) }}
					</button>
				</h3>
				<div id="collapse-dns-{{ $loc.Id }}" class="accordion-collapse collapse" aria-labelledby="heading-dns-{{ $loc.Id }}">
					<div class="accordion-body">
						<table class="table table-sm">
							<thead>
								<tr>
									<th>{{ $.Locale.T "table.name" }}</th>
									<th>{{ $.Locale.T "table.ping" }}</th>
									<th>{{ $.Locale.T "table.lookup" }}</th>
								</tr>
							</thead>
							<tbody>
								{{ range $dns := $loc.DnsResolverList }}
								<tr class="table-{{ if $dns.IsOperational }}success{{ else if $dns.IsDegraded }}warning{{ else }}danger{{ end }}">
									<td><a href="{{ $.Status.DetailURL "dns_resolver" $dns.Name }}">{{ $dns.Name }}</a></td>
									<td>
										{{ if $dns.Ping.IsUp }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.responding" }}" title="{{ $.Locale.T "status.responding" }}"></i>
										{{ else if $dns.Ping.IsWarning }}
										<i class="bi bi-question-circle text-warning" aria-label="{{ $.Locale.T "status.degraded" }}" title="{{ $.Locale.T "status.degraded" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.down" }}" title="{{ $.Locale.T "status.down" }}"></i>
										{{ end }}
									</td>
									<td>
										{{ if $dns.ResolveStatus }}
										<i class="bi bi-check-lg text-success" aria-label="{{ $.Locale.T "status.operational" }}" title="{{ $.Locale.T "status.operational" }}"></i>
										{{ else }}
										<i class="bi bi-exclamation-circle text-danger" aria-label="{{ $.Locale.T "status.error" }}" title="{{ $.Locale.T "status.error" }}"></i>
										{{ end }}
									</td>
								</tr>
								<tr class="history-row">
									<td colspan="3">{{ template "history_bar" ($.Status.HistoryFor "dns_resolver" $dns.Name) }}</td>
								</tr>
								{{ end }}
							</tbody>
						</table>
					</div>
				</div>
			</div> <!-- accordion item -->
			{{ end }}

		</div>
	</div>
</div>
{{ end }}

<div class="row">
	<div class="col">
		<h2>
			<a class="text-body text-decoration-none group-detail-link" href="{{ .Status.GroupDetailURL "services" "" }}">{{ .Locale.T "section.services" }} {{ template "status_counts" (dict "Counts" .Status.Services.Counts "Locale" .Locale) }}</a>
		</h2>
		<div class="mb-3">
			{{ template "history_bar" .Status.Services.History }}
		</div>

		<div class="accordion" id="accordion-services">
			<div class="accordion-item">
				<h3 class="accordion-header" id="heading-webservices">
