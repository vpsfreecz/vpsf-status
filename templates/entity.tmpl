{{ define "title" }}{{ .Entity.Label }} - {{ .Locale.T "app.title" }}{{ end }}

{{ define "content" }}
<nav class="navbar bg-light">
	<div class="container-fluid">
		<div class="navbar-brand clearfix">
			<a class="float-start" href="{{ .Locale.URL "/" }}">
				<img src="/static/vpsfree.png" alt="vpsFree.cz" width="180">
			</a>
			<h1 class="navbar-text float-start">{{ .Locale.T "nav.status" }}</h1>
		</div>
		<div class="d-flex align-items-center gap-3">
			<a class="navbar-link" href="{{ .Locale.URL "/" }}">{{ .Locale.T "nav.back_to_status" }}</a>
			<div class="dropdown">
				<button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ .Locale.T "language.label" }}">
					{{ .Locale.Name }}
				</button>
				<ul class="dropdown-menu dropdown-menu-end">
					{{ range .Locale.SwitchLinks }}
					<li><a class="dropdown-item{{ if .Active }} active{{ end }}" href="{{ .URL }}" title="{{ .Title }}"{{ if .Active }} aria-current="true"{{ end }}>{{ .Label }}</a></li>
					{{ end }}
				</ul>
			</div>
		</div>
	</div>
</nav>

<div class="row">
	<div class="col">
		<h2 class="text-{{ .Entity.StatusClass }}">{{ .Entity.Label }}</h2>
		<p>
			<span class="badge text-bg-secondary">{{ .Entity.Group }}</span>
			<span class="badge text-bg-{{ .Entity.StatusClass }}">{{ .Entity.StatusText }}</span>
		</p>
		{{ template "history_bar" .Entity.History }}
	</div>
</div>

{{ if .Entity.HasAvailability }}
<div class="row mt-4">
	<div class="col">
		<h2>{{ .Locale.T "section.availability" }}</h2>
		<table class="table table-sm w-auto">
			<thead>
				<tr>
					<th>{{ .Locale.T "table.period" }}</th>
					{{ if .Entity.ShowReportedAvailability }}
					<th class="text-end">{{ .Locale.T "table.reported" }}</th>
					{{ end }}
					<th class="text-end">{{ .Locale.T "table.probe" }}</th>
				</tr>
			</thead>
			<tbody>
				{{ range $stat := .Entity.Availability }}
				<tr>
					<td>{{ $stat.Label }}</td>
					{{ if $.Entity.ShowReportedAvailability }}
					<td class="text-end{{ if not $stat.ReportedAvailable }} text-muted{{ end }}">{{ $stat.Reported }}</td>
					{{ end }}
					<td class="text-end{{ if not $stat.ProbeAvailable }} text-muted{{ end }}">{{ $stat.Probe }}</td>
				</tr>
				{{ end }}
			</tbody>
		</table>
	</div>
</div>
{{ end }}

<div class="row mt-4">
	<div class="col">
		<h2>{{ .Locale.T "section.probe_log" }}</h2>
		{{ if .Entity.HasEvents }}
		<table class="table table-sm">
			<thead>
				<tr>
					<th>{{ .Locale.T "table.time" }}</th>
					{{ if .Entity.ShowEventEntity }}
					<th>{{ .Locale.T "table.entity" }}</th>
					{{ end }}
					<th>{{ .Locale.T "table.method" }}</th>
					<th>{{ .Locale.T "table.status" }}</th>
					<th>{{ .Locale.T "table.message" }}</th>
					<th>{{ .Locale.T "table.covered_by" }}</th>
				</tr>
			</thead>
			<tbody>
				{{ range $event := .Entity.Events }}
				<tr class="table-{{ $event.StatusClass }}{{ if $event.HasCoverage }} probe-covered probe-covered-{{ $event.CoveredBy.Class }}{{ if $event.GroupStart }} probe-covered-start{{ end }}{{ if $event.GroupEnd }} probe-covered-end{{ end }}{{ end }}">
					<td>{{ $event.ChangedAt }}</td>
					{{ if $.Entity.ShowEventEntity }}
					<td>{{ $event.Entity }}</td>
					{{ end }}
					<td>{{ $event.Method }}</td>
					<td>{{ $event.Status }}</td>
					<td>{{ $event.Message }}</td>
					<td>
						{{ if $event.HasCoverage }}
							{{ if $event.CoveredBy.URL }}
							<a class="badge text-bg-{{ $event.CoveredBy.Class }} text-decoration-none" href="{{ $event.CoveredBy.URL }}" target="_blank" rel="noopener">{{ $event.CoveredBy.Label }}</a>
							{{ else }}
							<span class="badge text-bg-{{ $event.CoveredBy.Class }}">{{ $event.CoveredBy.Label }}</span>
							{{ end }}
						{{ else }}
						<span class="text-muted">-</span>
						{{ end }}
					</td>
				</tr>
				{{ end }}
			</tbody>
		</table>
		{{ with .Entity.EventPagination }}
		{{ if .HasPages }}
		<nav aria-label="{{ $.Locale.T "probe_log.pages" }}">
			<ul class="pagination pagination-sm">
				<li class="page-item{{ if not .HasPrevious }} disabled{{ end }}">
					{{ if .HasPrevious }}
					<a class="page-link" href="{{ .PreviousURL }}">{{ $.Locale.T "probe_log.previous" }}</a>
					{{ else }}
					<span class="page-link">{{ $.Locale.T "probe_log.previous" }}</span>
					{{ end }}
				</li>
				{{ range $link := .Links }}
				<li class="page-item{{ if $link.Current }} active{{ end }}{{ if $link.Disabled }} disabled{{ end }}">
					{{ if $link.Disabled }}
					<span class="page-link">{{ $link.Label }}</span>
					{{ else if $link.Current }}
					<span class="page-link" aria-current="page">{{ $link.Label }}</span>
					{{ else }}
					<a class="page-link" href="{{ $link.URL }}">{{ $link.Label }}</a>
					{{ end }}
				</li>
				{{ end }}
				<li class="page-item{{ if not .HasNext }} disabled{{ end }}">
					{{ if .HasNext }}
					<a class="page-link" href="{{ .NextURL }}">{{ $.Locale.T "probe_log.next" }}</a>
					{{ else }}
					<span class="page-link">{{ $.Locale.T "probe_log.next" }}</span>
					{{ end }}
				</li>
			</ul>
		</nav>
		{{ end }}
		{{ end }}
		{{ else }}
		<div class="alert alert-secondary">{{ .Locale.T "probe_log.no_changes" }}</div>
		{{ end }}
	</div>
</div>
{{ end }}
