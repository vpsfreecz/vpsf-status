{{ define "history_bar" }}
<div class="history-bar{{ if .HasLanes }} history-bar-split{{ end }}" style="grid-template-columns: repeat({{ .DayCount }}, minmax(2px, 1fr));" aria-label="{{ .Label }} history">
	{{ range .Days }}
	<span class="history-day-wrap" tabindex="0" aria-label="{{ .SummaryLabel }}">
		{{ if .HasLanes }}
		<span class="history-day history-day-split">
			{{ range .Lanes }}
			<span class="history-lane {{ .Class }}" aria-hidden="true"></span>
			{{ end }}
		</span>
		{{ else }}
		<span class="history-day {{ .Class }}"></span>
		{{ end }}
		<span class="history-popover" role="tooltip">
			<span class="history-popover-date">{{ .Label }}</span>
			{{ if .HasIncidents }}
			<ul class="history-popover-list">
				{{ range .Incidents }}
				<li>
					{{ if .URL }}
					<a href="{{ .URL }}" target="_blank" rel="noopener">{{ .Text }}</a>
					{{ else }}
					{{ .Text }}
					{{ end }}
				</li>
				{{ end }}
			</ul>
			{{ else }}
			<span class="history-popover-empty">No incidents</span>
			{{ end }}
		</span>
	</span>
	{{ end }}
</div>
{{ end }}
